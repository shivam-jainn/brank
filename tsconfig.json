{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@brank/db": ["./packages/db/src/index.ts"],
      "@brank/db/client": ["./packages/db/generated/client.ts"],
      "@brank/inferhence": ["./packages/inferhence/src/index.ts"],
      "@brank/ingestion": ["./packages/ingestion/src/index.ts"],
      "@brank/providers": ["./packages/providers/registry.ts"],
      "@brank/providers/*": ["./packages/providers/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
